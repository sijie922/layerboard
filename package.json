{
  "name": "layerboard",
  "version": "1.0.0",
  "private": true,
  "description": "LayerBoard - 无限缩放团队协作画板",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:client": "turbo run dev --filter=layerboard-client",
    "dev:server": "turbo run dev --filter=layerboard-server",
    "build": "turbo run build",
    "build:client": "turbo run build --filter=layerboard-client",
    "build:server": "turbo run build --filter=layerboard-server",
    "lint": "turbo run lint",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
